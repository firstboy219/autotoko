# --- AutoToko backend ---
NODE_ENV=development
HOST=0.0.0.0
PORT=8080

# Database (reuse shared postgres on the server; new DB "autotoko")
DATABASE_URL=postgresql://autotoko_user:CHANGE_ME@localhost:5432/autotoko

# Redis (own small instance, mem-limited)
REDIS_URL=redis://localhost:6379

# App
APP_URL=http://localhost:5173

# Auth
JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=CHANGE_ME
REFRESH_TOKEN_EXPIRES_IN=30d

# Dev dummy login (frontend convenience) — DISABLE in production
DEV_LOGIN_ENABLED=true
DEV_LOGIN_USERNAME=user
DEV_LOGIN_PASSWORD=user

# WhatsApp login (RECEIVE-ONLY). Shared with xtracker's WA number + n8n.
# n8n routes messages prefixed "AUTOTOKO-" to /api/auth/wa-login/verify.
WA_AUTOTOKO_NUMBER=628xxxxxxxxxx
WA_WEBHOOK_SECRET=CHANGE_ME

# AES-256 (32-byte) key for encrypting marketplace tokens at rest
ENCRYPTION_KEY=CHANGE_ME_32_BYTES

# n8n (shared instance) — internal auth
N8N_WEBHOOK_BASE_URL=http://localhost:5678
INTERNAL_API_TOKEN=CHANGE_ME

# Cloudflare R2 (S3-compatible object storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=autotoko
R2_PUBLIC_URL=

# AI (Claude now; provider/model overridable via Admin CMS)
ANTHROPIC_API_KEY=
AI_PROVIDER=anthropic
AI_MODEL=claude-opus-4-8

# Payment
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
