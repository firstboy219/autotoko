# --- AutoToko backend ---
NODE_ENV=development
HOST=0.0.0.0
PORT=8080

# Database (reuse shared postgres on the server; new DB "autotoko")
DATABASE_URL=postgresql://autotoko_user:CHANGE_ME@localhost:5432/autotoko

# Redis (own small instance, mem-limited)
REDIS_URL=redis://localhost:6379

# App
APP_URL=http://localhost:5173

# Auth
JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=CHANGE_ME
REFRESH_TOKEN_EXPIRES_IN=30d

# Admin CMS login (real account; works in production). Set a strong password.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG

# Dev dummy login (frontend convenience). Only honored when NODE_ENV != production.
# Defaults to disabled; never relied on in production.
DEV_LOGIN_ENABLED=false
DEV_LOGIN_USERNAME=user
DEV_LOGIN_PASSWORD=user

# Email OTP login (reuses xtracker Gmail SMTP). Leave blank to disable email login.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=AutoToko <muhilhamps@gmail.com>

# WhatsApp login (RECEIVE-ONLY). Shared with xtracker's WA number + n8n.
# n8n routes messages prefixed "AUTOTOKO-" to /api/auth/wa-login/verify.
WA_AUTOTOKO_NUMBER=628xxxxxxxxxx
WA_WEBHOOK_SECRET=CHANGE_ME

# AES-256 (32-byte) key for encrypting marketplace tokens at rest
ENCRYPTION_KEY=CHANGE_ME_32_BYTES

# n8n (shared instance) — internal auth
N8N_WEBHOOK_BASE_URL=http://localhost:5678
INTERNAL_API_TOKEN=CHANGE_ME

# Marketplace order webhooks: POST /api/webhooks/{tiktok|shopee}
# REQUIRED — endpoints fail closed (reject all) when empty. The webhook URL
# registered in each dashboard must include ?secret=<this> (until native sig
# verification is wired).
WEBHOOK_INGEST_SECRET=CHANGE_ME_RANDOM

# Cloudflare R2 (S3-compatible object storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=autotoko
R2_PUBLIC_URL=

# AI (Claude now; provider/model overridable via Admin CMS)
ANTHROPIC_API_KEY=
AI_PROVIDER=anthropic
AI_MODEL=claude-opus-4-8

# --- Marketplace credentials are managed via Admin CMS (admin_settings,
# AES-encrypted), NOT here. Adapter keys: tiktok_app_key, tiktok_app_secret,
# tiktok_auth_url, shopee_partner_id, shopee_partner_key, shopee_redirect_url.
# Register these OAuth callbacks with each marketplace:
#   {API host}/api/shops/callback/tiktok
#   {API host}/api/shops/callback/shopee

# Payment
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
